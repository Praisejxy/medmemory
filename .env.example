# Copy this file to .env and fill in real values. NEVER commit .env itself.

# Qwen Cloud API credentials (https://home.qwencloud.com/benefits -> API Keys)
QWEN_API_KEY=your-qwen-api-key-here
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Set to "false" to hit the real Qwen API. Defaults to "true" (mock mode)
# so the project can be run and tested with zero API cost.
QWEN_MOCK_MODE=true

# Local persistence paths (overridden to /tmp/* automatically on
# Alibaba Cloud Function Compute — see backend/fc_handler.py)
MEDMEMORY_DB_PATH=./medmemory.db
MEDMEMORY_CHROMA_PATH=./chroma_store
